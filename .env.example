# =============================================================================
# selfpotify - configuración por instalación
# Copia este archivo a `.env` y ajusta los valores. `.env` no se versiona.
# Las variables de entorno reales del SO tienen prioridad sobre las de `.env`.
# =============================================================================

# --- Server ---
# Puerto en el que escucha el backend Spring Boot.
SERVER_PORT=8080

# --- Database -----------------------------------------------------------------
# Por defecto: H2 en memoria (datos se pierden al reiniciar, ideal para desarrollo).
# Para producción: cambiar a Postgres/MySQL y añadir el driver correspondiente al pom.xml.
DB_URL=jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver
DB_DIALECT=org.hibernate.dialect.H2Dialect
# create-drop: recrea tablas al arrancar. update: conserva datos. validate/none: producción.
DB_DDL_AUTO=create-drop
DB_SHOW_SQL=true

# --- Initial admin (auto-bootstrap al primer arranque) ------------------------
# Si no existe ningún admin en BBDD, se crea uno con estas credenciales al arrancar.
# Si ya existe al menos un admin, se ignoran. Dejar vacíos para deshabilitar el bootstrap.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Security -----------------------------------------------------------------
# JWT_SECRET: cadena aleatoria de mínimo 32 caracteres. Generar p.ej. con `openssl rand -base64 48`.
JWT_SECRET=please-change-me-to-a-long-random-string-min-32-chars
# Vida del token en milisegundos (86400000 = 24h).
JWT_EXPIRATION_MS=86400000

# --- App ----------------------------------------------------------------------
# Ruta al fichero YAML de configuración runtime del servidor.
# Deja la línea comentada para usar el default (~/.selfpotify/config.yml).
#APP_CONFIG_PATH=/ruta/personalizada/config.yml
# Consola de administración H2 (solo desarrollo; deshabilitar en producción).
H2_CONSOLE_ENABLED=true
H2_CONSOLE_PATH=/h2-console

# --- Web (frontend) -----------------------------------------------------------
# Origen del frontend (para CORS). El frontend Next.js corre como proceso separado.
# - Desarrollo local (start.sh, pnpm dev en :8081): WEB_ORIGIN=http://localhost:8081
# - Despliegue Docker (docker compose, Nginx en :80): WEB_ORIGIN=http://localhost
WEB_ORIGIN=http://localhost:3000

# --- Librería musical (OBLIGATORIO en Docker) ---------------------------------
# Carpeta del host con tus MP3. Se monta de solo lectura en /music dentro del
# contenedor `api`, así que los paths que añadas en el wizard / panel deben
# empezar por /music (p.ej. /music o /music/Artista/Album).
# `docker compose up` aborta si esta variable está vacía o sin definir.
# Ejemplo: MUSIC_LIBRARY_PATH=/Users/tu-usuario/Música
# En macOS, si la ruta está fuera de $HOME, autoriza la carpeta en
# Docker Desktop → Settings → Resources → File Sharing.
MUSIC_LIBRARY_PATH=
# Punto de montaje de la librería DENTRO del contenedor `api`. El backend la
# auto-añade a las rutas de escaneo en el primer arranque. Normalmente no hace
# falta cambiarlo; debe coincidir con el destino del volumen en docker-compose.yml.
#MUSIC_LIBRARY_MOUNT=/music

# --- Last.fm (clasificación automática de género) -----------------------------
# Clave de API de Last.fm. Sin ella, la importación de canciones no asigna género.
# Obtén una en https://www.last.fm/api/account/create
LASTFM_API_KEY=
# URL base de la API de Last.fm. Normalmente no hace falta cambiarla.
LASTFM_BASE_URL=https://ws.audioscrobbler.com/2.0/

# --- Subida del logo ----------------------------------------------------------
# Tamaño máximo del logo subido en el wizard / panel admin (POST /api/config/logo).
# Acepta sufijos de Spring DataSize: KB, MB, GB. El front muestra este límite y
# redimensiona la imagen en cliente si lo supera.
LOGO_MAX_FILE_SIZE=2MB

# =============================================================================
# Notas para despliegue con Docker (docker compose):
# - APP_CONFIG_PATH lo fija el contenedor a /data/selfpotify/config.yml. No lo
#   sobreescribas desde aquí cuando uses docker compose: la ruta apunta al
#   volumen `selfpotify-data` que persiste config.yml + assets entre reinicios.
# - H2_CONSOLE_ENABLED=false recomendado en producción.
# - Para persistir la BBDD entre reinicios del contenedor, cambia DB_URL a:
#     DB_URL=jdbc:h2:file:/data/selfpotify/db/selfpotify;AUTO_SERVER=TRUE
#     DB_DDL_AUTO=update
# - El contenedor `web` (Nginx :80) hace proxy_pass /api/ y /assets/ al backend,
#   así que el navegador habla siempre con :80 y no hay CORS. El cliente Android
#   accede directamente a :8080 (puerto del contenedor `api`).
# =============================================================================
# Añadir aquí variables nuevas a medida que se integren servicios externos:
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# =============================================================================
