# =============================================================================
# selfpotify - configuración por instalación
# Copia este archivo a `.env` y ajusta los valores. `.env` no se versiona.
# Las variables de entorno reales del SO tienen prioridad sobre las de `.env`.
# =============================================================================

# --- Server ---
# Puerto en el que escucha el backend Spring Boot. Si se hace la instalación
# con docker, debe hacerse
SERVER_PORT=8080
# SOLO PARA DOCKER - Puerto en el que escucha Nginx (cliente web, por defecto 80).
# Cambiar aquí si no puedes usar :80 (requiere permisos de root o puerto ocupado).
WEB_PORT=80

# --- Database -----------------------------------------------------------------
# Por defecto: H2 en fichero (datos persistentes, sobreviven a reinicios).
# Para H2 en memoria (efímera): jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
# Para producción: cambiar a Postgres/MySQL y añadir el driver correspondiente al pom.xml.
#
# IMPORTANTE — la ruta depende del modo de despliegue:
#   Bare metal (desarrollo local): ruta relativa al directorio del proyecto.
#     DB_URL=jdbc:h2:file:./data/selfpotify;AUTO_SERVER=TRUE
#   Docker (docker compose): ruta absoluta dentro del volumen del contenedor.
#     DB_URL=jdbc:h2:file:/data/selfpotify/db/selfpotify;AUTO_SERVER=TRUE
#
DB_URL=jdbc:h2:file:./data/selfpotify;AUTO_SERVER=TRUE
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver
DB_DIALECT=org.hibernate.dialect.H2Dialect
# create-drop: recrea tablas al arrancar. update: conserva datos. validate/none: producción.
DB_DDL_AUTO=update
DB_SHOW_SQL=true

# --- Initial admin (auto-bootstrap al primer arranque) ------------------------
# Si no existe ningún admin en BBDD, se crea uno con estas credenciales al arrancar.
# Si ya existe al menos un admin, se ignoran. Dejar vacíos para deshabilitar el bootstrap.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Security -----------------------------------------------------------------
# JWT_SECRET: cadena aleatoria de mínimo 32 caracteres. Generar p.ej. con `openssl rand -base64 48`.
JWT_SECRET=please-change-me-to-a-long-random-string-min-32-chars
# Vida del token en milisegundos (86400000 = 24h).
JWT_EXPIRATION_MS=86400000

# --- App ----------------------------------------------------------------------
# Ruta al fichero YAML de configuración runtime del servidor.
# Deja la línea comentada para usar el default (~/.selfpotify/config.yml).
#APP_CONFIG_PATH=/ruta/personalizada/config.yml
# Consola de administración H2 (solo desarrollo; deshabilitar en producción).
H2_CONSOLE_ENABLED=true
H2_CONSOLE_PATH=/h2-console

# --- Web (frontend) -----------------------------------------------------------
# Origen del frontend (para CORS). El frontend Next.js corre como proceso separado.
# - Desarrollo local WEB_ORIGIN=http://localhost:3000
# - Despliegue Docker (docker compose, Nginx en :80): WEB_ORIGIN=http://localhost
WEB_ORIGIN=http://localhost:3000

# --- Librería musical (OBLIGATORIO en Docker) ---------------------------------
# Carpeta del host con tus MP3. En bare metal, se añade directamente a las rutas.
# En docker se monta en /music dentro del contenedor. Cuando añadas canciones desde
# el panel de admin, se añadirán a una carpeta creada dentro llamada "selfpotify_added"
# Ejemplo: MUSIC_LIBRARY_PATH=/Users/tu-usuario/Música
MUSIC_LIBRARY_PATH=
# En macOS, si la ruta está fuera de $HOME, autoriza la carpeta en
# Docker Desktop → Settings → Resources → File Sharing.

# Punto de montaje de la librería DENTRO del contenedor `api`. El backend la
# auto-añade a las rutas de escaneo en el primer arranque. Normalmente no hace
# falta cambiarlo; debe coincidir con el destino del volumen en docker-compose.yml.
#MUSIC_LIBRARY_MOUNT=/music

# --- Last.fm (clasificación automática de género) -----------------------------
# Clave de API de Last.fm. Sin ella, la importación de canciones no asigna género.
# Obtén una en https://www.last.fm/api/account/create
# Además, el wizard de setup sólo deja activar "Autocompletar metadatos" si esta
# clave está definida (si está vacía, el interruptor aparece deshabilitado).
LASTFM_API_KEY=
# URL base de la API de Last.fm. Normalmente no hace falta cambiarla.
LASTFM_BASE_URL=https://ws.audioscrobbler.com/2.0/

# --- Carátulas / fotos automáticas (SIN API key) ------------------------------
# Durante el escaneo, el servidor rellena la carátula de cada canción/álbum y la
# foto de cada artista que no la tengan. Prioridad: carátula EMBEBIDA en el
# archivo (se vuelca a /assets/covers) → fuentes online keyless (Cover Art
# Archive vía MusicBrainz → iTunes → Deezer) → si no hay nada, queda vacío.
# No requiere ninguna key; estos valores sólo afinan el comportamiento.
# Poner a false para desactivar por completo la resolución online de carátulas.
COVER_ART_ENABLED=true
# User-Agent enviado a MusicBrainz (su política de uso EXIGE identificar la app
# y un contacto). Cámbialo por el tuyo: "MiApp/version ( contacto-o-url )".
COVER_ART_USER_AGENT=selfpotify/1.0 ( https://github.com/selfpotify )
# Timeouts (ms) de las llamadas a las fuentes externas de carátulas.
COVER_ART_CONNECT_TIMEOUT_MS=4000
COVER_ART_READ_TIMEOUT_MS=6000

# --- Carátulas / fotos automáticas (SIN API key) ------------------------------
# Durante el escaneo, el servidor rellena la carátula de cada canción/álbum y la
# foto de cada artista que no la tengan. Prioridad: carátula EMBEBIDA en el
# archivo (se vuelca a /assets/covers) → fuentes online keyless (Cover Art
# Archive vía MusicBrainz → iTunes → Deezer) → si no hay nada, queda vacío.
# No requiere ninguna key; estos valores sólo afinan el comportamiento.
# Poner a false para desactivar por completo la resolución online de carátulas.
# El wizard de setup sólo deja activar "Autocompletar carátulas" si esto es true
# (si está en false, el interruptor aparece deshabilitado), igual que LASTFM_API_KEY
# gobierna el de "Autocompletar metadatos".
COVER_ART_ENABLED=true
# User-Agent enviado a MusicBrainz (su política de uso EXIGE identificar la app
# y un contacto). Cámbialo por el tuyo: "MiApp/version ( contacto-o-url )".
COVER_ART_USER_AGENT=selfpotify/1.0 ( https://github.com/selfpotify )
# Timeouts (ms) de las llamadas a las fuentes externas de carátulas.
COVER_ART_CONNECT_TIMEOUT_MS=4000
COVER_ART_READ_TIMEOUT_MS=6000

# --- Subida del logo ----------------------------------------------------------
# Tamaño máximo del logo subido en el wizard / panel admin (POST /api/config/logo).
# Acepta sufijos de Spring DataSize: KB, MB, GB. El front muestra este límite y
# redimensiona la imagen en cliente si lo supera. El logo se valida a nivel de
# aplicación; el límite global de multipart lo marca SONG_UPLOAD_MAX_FILE_SIZE.
LOGO_MAX_FILE_SIZE=2MB

# --- Subida de canciones (drag & drop en el panel admin) ----------------------
# Audios subidos vía POST /api/songs/upload. Se guardan en una carpeta
# selfpotify_added dentro del volumen de datos (en Docker, /data/selfpotify) o de
# la ruta de música elegida (en local), y se incorporan a la biblioteca.
# Aceptan sufijos de Spring DataSize: KB, MB, GB.
# SONG_UPLOAD_MAX_FILE_SIZE marca también el límite global de multipart de Spring.
# SONG_UPLOAD_MAX_FILE_SIZE: tamaño máximo por archivo (por defecto 50MB).
# SONG_UPLOAD_MAX_REQUEST_SIZE: tamaño máximo de la petición al subir varios (500MB).
SONG_UPLOAD_MAX_FILE_SIZE=50MB
SONG_UPLOAD_MAX_REQUEST_SIZE=500MB
