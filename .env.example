# =============================================================================
# selfpotify - configuración por instalación
# Copia este archivo a `.env` y ajusta los valores. `.env` no se versiona.
# Las variables de entorno reales del SO tienen prioridad sobre las de `.env`.
# =============================================================================

# --- Server ---
# Puerto en el que escucha el backend Spring Boot.
SERVER_PORT=8080

# --- Database -----------------------------------------------------------------
# Por defecto: H2 en memoria (datos se pierden al reiniciar, ideal para desarrollo).
# Para producción: cambiar a Postgres/MySQL y añadir el driver correspondiente al pom.xml.
DB_URL=jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
DB_USERNAME=sa
DB_PASSWORD=
DB_DRIVER=org.h2.Driver
DB_DIALECT=org.hibernate.dialect.H2Dialect
# create-drop: recrea tablas al arrancar. update: conserva datos. validate/none: producción.
DB_DDL_AUTO=create-drop
DB_SHOW_SQL=true

# --- Initial admin (auto-bootstrap al primer arranque) ------------------------
# Si no existe ningún admin en BBDD, se crea uno con estas credenciales al arrancar.
# Si ya existe al menos un admin, se ignoran. Dejar vacíos para deshabilitar el bootstrap.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# --- Security -----------------------------------------------------------------
# JWT_SECRET: cadena aleatoria de mínimo 32 caracteres. Generar p.ej. con `openssl rand -base64 48`.
JWT_SECRET=please-change-me-to-a-long-random-string-min-32-chars
# Vida del token en milisegundos (86400000 = 24h).
JWT_EXPIRATION_MS=86400000

# --- App ----------------------------------------------------------------------
# Ruta al fichero YAML de configuración runtime del servidor (vacío = ~/.selfpotify/config.yml).
APP_CONFIG_PATH=
# Consola de administración H2 (solo desarrollo; deshabilitar en producción).
H2_CONSOLE_ENABLED=true
H2_CONSOLE_PATH=/h2-console

# --- Web (frontend) -----------------------------------------------------------
# Origen del frontend (para CORS). El frontend Next.js corre como proceso separado.
WEB_ORIGIN=http://localhost:3000

# =============================================================================
# Añadir aquí variables nuevas a medida que se integren servicios externos:
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# =============================================================================
