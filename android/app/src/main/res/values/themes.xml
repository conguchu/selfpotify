<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Tema base oscuro estilo Spotify (CLAUDE.md §3). Siempre oscuro: no se usa DayNight.
        Los colores son los de FALLBACK; el branding real (dinámico, del servidor) se
        aplica en runtime sobre estos valores.
    -->
    <style name="Theme.Selfpotify" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/fallback_accent</item>
        <item name="colorOnPrimary">@color/fallback_on_accent</item>
        <item name="colorSecondary">@color/fallback_accent</item>
        <item name="colorOnSecondary">@color/fallback_on_accent</item>
        <item name="android:colorBackground">@color/fallback_bg</item>
        <item name="colorSurface">@color/fallback_surface</item>
        <item name="colorOnSurface">@color/fallback_text_primary</item>
        <item name="colorError">@color/fallback_error</item>
        <item name="android:statusBarColor">@color/fallback_bg</item>
        <item name="android:navigationBarColor">@color/fallback_bg</item>
    </style>
</resources>
